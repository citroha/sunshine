  <script>
    document.getElementById('year').textContent = new Date().getFullYear();

    // Reveal phase cards on scroll (progressive enhancement only —
    // cards are fully visible via CSS even if this never runs).
    const phases = document.querySelectorAll('.phase');
    phases.forEach(p => p.classList.add('js-reveal'));
    const io = new IntersectionObserver((entries) => {
      entries.forEach((entry, i) => {
        if (entry.isIntersecting) {
          setTimeout(() => entry.target.classList.add('in-view'), i * 90);
          io.unobserve(entry.target);
        }
      });
    }, { threshold: 0.25 });
    phases.forEach(p => io.observe(p));
  </script>

